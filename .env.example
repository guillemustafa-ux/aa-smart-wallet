# Copiá este archivo como `.env` y completá los valores.
# El .env NUNCA se sube a git (está en .gitignore).

# RPC de Sepolia. Sacá una gratis en Alchemy (alchemy.com) o Infura.
# Ejemplo Alchemy: https://eth-sepolia.g.alchemy.com/v2/TU_API_KEY
SEPOLIA_RPC_URL=

# API key de Etherscan (etherscan.io/myapikey). Con Etherscan API V2 esta misma
# key verifica en todas las redes (se enruta por chainid).
ETHERSCAN_API_KEY=

# API key de Pimlico (dashboard.pimlico.io). Da el bundler + el paymaster de
# patrocinio para el flujo gasless del frontend.
PIMLICO_API_KEY=

# (Opcional) Override del EntryPoint. Si no se setea, el deploy usa el v0.7
# canónico: 0x0000000071727De22E5E9d8BAf0edAc6f37da032
# ENTRYPOINT=

# Clave privada de la wallet que despliega.
# ⚠️ USÁ UNA WALLET DE PRUEBA, descartable, SIN fondos reales. Solo ETH de faucet.
# ⚠️ NUNCA pongas acá la clave de una wallet con plata de verdad.
PRIVATE_KEY=
