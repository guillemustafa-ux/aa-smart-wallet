# Copiá como `.env` y completá. En Vite, las VITE_* quedan EMBEBIDAS en el bundle
# (visibles en el cliente). Para un demo de testnet está OK; en producción se proxea
# el paymaster por un backend o se restringe con sponsorship policies de Pimlico.

# API key de Pimlico (dashboard.pimlico.io) — bundler + paymaster.
VITE_PIMLICO_API_KEY=

# Opcional: RPC propio de Sepolia para las lecturas (si se deja vacío usa el público).
VITE_SEPOLIA_RPC_URL=
